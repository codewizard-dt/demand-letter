{
  "name": "@demand-letter/web",
  "version": "3.2.1",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test e2e/e2e.spec.ts",
    "test:e2e:ui": "playwright test e2e/e2e.spec.ts --ui",
    "test:e2e:headed": "playwright test e2e/e2e.spec.ts --headed",
    "test:e2e:report": "playwright show-report",
    "test:e2e:auth": "playwright test e2e/auth.spec.ts",
    "test:e2e:lifecycle": "playwright test e2e/full-job-lifecycle.spec.ts",
    "test:e2e:account": "playwright test e2e/account.spec.ts",
    "test:e2e:admin": "playwright test e2e/admin-usage.spec.ts",
    "test:e2e:jobs-list": "playwright test e2e/jobs-list-after-lifecycle.spec.ts",
    "create-fixtures": "node scripts/create-fixtures.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.80.7",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-collaboration": "^3.27.1",
    "@tiptap/extension-collaboration-cursor": "^2.26.2",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "diff": "^9.0.0",
    "docx-preview": "^0.3.7",
    "lucide-react": "^0.523.0",
    "mammoth": "^1.12.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.30.4",
    "y-prosemirror": "^1.3.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tanstack/react-query-devtools": "^5.80.7",
    "@types/diff": "^8.0.0",
    "@types/node": "^24.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "docx": "^9.7.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3",
    "typescript": "*",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=24 <25"
  },
  "type": "module"
}
