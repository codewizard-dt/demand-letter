{
  "name": "@demand-letter/web",
  "version": "0.5.2",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "preview": "vite preview",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:report": "playwright show-report",
    "create-fixtures": "node scripts/create-fixtures.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.80.7",
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-collaboration": "^3.27.1",
    "@tiptap/extension-collaboration-cursor": "^2.26.2",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "diff": "^9.0.0",
    "mammoth": "^1.12.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "react-router-dom": "^6.30.4",
    "y-prosemirror": "^1.3.7",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@tanstack/react-query-devtools": "^5.80.7",
    "@types/diff": "^8.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "autoprefixer": "^10.5.0",
    "docx": "^9.7.1",
    "postcss": "^8.5.15",
    "tailwindcss": "^3",
    "typescript": "*",
    "vite": "^5.0.0",
    "vitest": "^2.0.0"
  }
