{
  "name": "@demand-letter/api",
  "version": "0.5.3",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc --project tsconfig.json && node scripts/build-handlers.mjs",
    "compliance-verify": "tsx src/lib/compliance-verify.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 50",
    "test": "vitest run --passWithNoTests",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.0.0",
    "@aws-sdk/client-bedrock-runtime": "^3.0.0",
    "@aws-sdk/client-comprehend": "^3.0.0",
    "@aws-sdk/client-comprehendmedical": "^3.0.0",
    "@aws-sdk/client-dynamodb": "^3.0.0",
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/client-textract": "^3.1074.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@demand-letter/db": "workspace:*",
    "@prisma/client": "^5.0.0",
    "docx": "^9.7.1",
    "docxtemplater": "^3.69.0",
    "dotenv": "^16.0.0",
    "fast-xml-parser": "^5.9.3",
    "lambda-multipart-parser": "^1.0.1",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "pdfjs-dist": "^6.0.227",
    "pizzip": "^3.2.0",
    "yjs": "^13.6.31"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.0",
    "@types/busboy": "^1.5.4",
    "@types/node": "*",
    "@types/pdf-parse": "^1.1.5",
    "@types/pizzip": "^3.1.2",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "aws-sdk-client-mock": "^4.0.0",
    "aws-sdk-client-mock-vitest": "^4.0.0",
    "eslint": "^8.56.0",
    "tsx": "^4.0.0",
    "typescript": "*",
    "vitest": "^2.0.0",
    "vitest-mock-extended": "^2.0.0"
  }
}
