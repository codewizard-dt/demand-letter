# Database
# Host tools (prisma migrate, psql): use the mapped Docker port
DATABASE_URL=postgresql://postgres@localhost:5430/demand_letter_dev
# SAM Lambda containers use the service hostname — see env.json
# DATABASE_URL=postgresql://postgres@postgres/demand_letter_dev

# Used by UAT test scripts to hit the local SAM API
API_BASE_URL=http://127.0.0.1:3000

# Amazon Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_REGION=us-east-1

# Stage
STAGE=dev

# WebSocket API URL for real-time Y.js collaboration (e.g. wss://xxx.execute-api.us-east-1.amazonaws.com/prod)
VITE_WS_API_URL=wss://your-api-id.execute-api.us-east-1.amazonaws.com/prod
