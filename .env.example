# Database — local development (peer auth via Unix socket, no password needed)
# macOS homebrew postgres: the DB owner is your OS user, not 'postgres'
DATABASE_URL=postgresql://localhost/demand_letter_dev

# Used by UAT test scripts to hit the local SAM API
API_BASE_URL=http://127.0.0.1:3000

# Amazon Bedrock
BEDROCK_MODEL_ID=us.anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_REGION=us-east-1

# Stage
STAGE=dev

# SAM local note: Lambda containers cannot reach localhost — see env.json for
# the SAM local env-var overrides (DATABASE_URL uses host.docker.internal there).

# WebSocket API URL for real-time Y.js collaboration (e.g. wss://xxx.execute-api.us-east-1.amazonaws.com/prod)
VITE_WS_API_URL=wss://your-api-id.execute-api.us-east-1.amazonaws.com/prod
